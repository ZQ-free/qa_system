# ══════════════════════════════════════════════
# 数据库 Tool 开关
# on  = 开启该数据库 Tool，LangChain Agent 可调用
# off = 禁用，初始化时跳过，不注入对应 Prompt
# ══════════════════════════════════════════════
ENABLE_MYSQL=on
ENABLE_NEO4J=off

# ══════════════════════════════════════════════
# MySQL 数据库连接
# ══════════════════════════════════════════════
MYSQL_HOST=47.96.152.190
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=!software2303
MYSQL_DB=overseas_chinese_artifacts

# ══════════════════════════════════════════════
# Neo4j 图数据库
# ══════════════════════════════════════════════
NEO4J_URI=bolt://10.4.70.168:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# ══════════════════════════════════════════════
# 大语言模型（OpenAI 兼容协议）
# 支持任意兼容 OpenAI 协议的服务，只需修改下面三个配置：
#
# 厂商          base_url                                      model_name
# ─────────────────────────────────────────────────────────────────────────
# DeepSeek      https://api.deepseek.com/v1                   deepseek-chat
# 通义千问       https://dashscope.aliyuncs.com/compatible-mode/v1  qwen-plus
# 智谱GLM       https://open.bigmodel.cn/api/paas/v4          glm-4
# Ollama本地    http://localhost:11434/v1                       qwen2.5
# vLLM本地      http://localhost:8000/v1                        your-model
# OpenAI        https://api.openai.com/v1                      gpt-4o-mini
# ══════════════════════════════════════════════
LLM_BASE_URL=https://token.sensenova.cn/v1
LLM_API_KEY=sk-nJOBjdC4pshObIuxa7BicfFoGoue2Tho
LLM_MODEL_NAME=sensenova-6.7-flash-lite

# LLM 生成参数
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

# ══════════════════════════════════════════════
# 会话配置
# ══════════════════════════════════════════════
SESSION_MAX_TURNS=5